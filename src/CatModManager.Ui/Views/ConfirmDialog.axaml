<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CatModManager.Ui.Views.ConfirmDialog"
        Title="Confirm"
        Width="360" Height="160"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackground}"
        Foreground="{DynamicResource TextPrimary}">
    <Grid RowDefinitions="*, Auto" Margin="24">
        <StackPanel Grid.Row="0" Spacing="6" VerticalAlignment="Center">
            <TextBlock Name="TitleText" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
            <TextBlock Name="BodyText" FontSize="12" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Name="CancelBtn" Content="Cancel" Padding="16,6" Background="Transparent"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"/>
            <Button Name="ConfirmBtn" Content="Delete" Padding="16,6"
                    Background="#C0392B" Foreground="White" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
